NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-with-a-strong-random-secret
AUTH_SECRET=

# Google OAuth. Optional locally; required to activate the Google button in production.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Future production persistence.
DATABASE_URL=postgresql://user:password@host:5432/vinovalor?sslmode=require

# Abuse protection placeholders.
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
UPLOAD_MAX_MB=8
